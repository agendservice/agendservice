meta {
  name: Criar Servico
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/servicos
  body: json
  auth: none
}

body:json {
  {
    "empresa_id": {{empresaId}},
    "nome": "Corte de Cabelo",
    "duracao_minutos": 40,
    "preco": 35.00
  }
}

script:post-response {
  if (res.status === 201) {
    bru.setVar("servicoId", res.body.data.id);
  }
}

tests {
  test("Status deve ser 201", function() {
    expect(res.status).to.equal(201);
  });
}
