meta {
  name: Criar Empresa
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/empresas
  body: json
  auth: none
}

body:json {
  {
    "nome": "Barbearia Estilo",
    "cnpj": "12.345.678/0001-90",
    "endereco": "Rua das Flores, 123",
    "telefone": "8533334444"
  }
}

script:post-response {
  if (res.status === 201) {
    bru.setVar("empresaId", res.body.data.id);
  }
}

tests {
  test("Status deve ser 201", function() {
    expect(res.status).to.equal(201);
  });
}
